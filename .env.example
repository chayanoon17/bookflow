# Supabase — copy host จาก Dashboard → Connect → Database (อย่าเดา aws-0)
# Transaction pooler (6543) — ใช้บน Vercel / runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler (5432) — prisma db push ในเครื่อง
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

# สร้างด้วย: openssl rand -base64 32
AUTH_SECRET="your-auth-secret"
# Local: http://localhost:3000 | Production: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"
APP_TIMEZONE="Asia/Bangkok"
